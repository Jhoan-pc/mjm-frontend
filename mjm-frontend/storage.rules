rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /tenants/deltapruebas-sandbox/{allPaths=**} {
      allow read, write: if true;
    }
    match /tenants/t_backup/{allPaths=**} {
      allow read, write: if true;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
